Plantillas de generación de código.
Equivalen a lo que tenemos en los visitors "ExecuteCGVisitor", "ValueCGVisitor" y "AddressCGVisitor"

// PLANTILLAS EXECUTE (statements, definitions, program)
1. Assigment                                                                            ✅
    execute[[Assigment: stmt -> expr1 expr2]]()=
        address[[expr1]]()
        value[[expr2]]()
        cg.convertTo(expr2.type, expr1.type)
        <store> expr1.type.suffix()

2. Input                                                                                ✅
    execute[[Input: stmt -> expr]]()=
        <#line> expr.line
        < ' * Read>
        address[[expr]]()
        <in> expr.type.suffix
        <store> expr.type.suffix

3. Log                                                                                  ✅
    execute[[Log: stmt -> expr]]()=
        <#line> expr.line
        < ' * Write>
        value[[expr]]
        <out> expr.type.suffix

3. VarDefinition                                                                         ✅
    execute[[VarDefinition: definition -> type ID]](){
        < ' * > type ID <(offset > type.offset <)>
    }

4. FunctionDefinition                                                                    ✅
    execute[[FunctionDefinition: definition -> ID type stmt*]]()=
        ID <:>
        < ' * Parameters: >
        for(VarDefinition v: type.params){
            exectue[[v]]();
        }
        < ' * Local Variables: >
        for(Statements st: stmt*){
            if(st instanceof VarDefinition){
                definitions*.add(st);
                execute[[st]]();
            }
        }
        if(definitions*.isEmpty()){
            defintion.bytesLocalSum = 0;
        }
        else {
            VarDefinition ultimaVardefintion = definition*.get(definition*.size()-1)
            definition.bytesLocalSum = -1 * ultimaVardefinition.offset
        }

        <enter> definitions.bytesLocalSum
        for(Statements st:stmt*){
            if(!(st instaceof VarDefinition)){
                execute[[st]]
            }
        }
        <ret> 0, definitions.bytesLocalSum, 0

5. While ->
    execute[[While: stmt1 -> expr stmt2*]]()=
        String cond = cg.getLabel()
        String end = cg.getLabel()
        cond <:>
        value[[expr]]()
        cg.convertTo(expr.type, IntType.instance)
        <jz> end
        stmt2*.forEach(s -> execute[[s]]())
        <jmp> cond
        end <:>

6. If_else ->
    execute[[If_else: stmt1 -> expr stmt2* stmt3*]]()=
        String else = cg.getLabel()
        String end = cg.getLabel()
        value[[expr]]()
        cg.convertTo(expr.type, IntType.instance)
        <jz> else
        stmt2*.forEach(s -> execute[[s]]())
        <jmp> end
        else <:>
        stmt3*.forEach(s -> execute[[s]]())
        end <:>

5. Program ->                                                                           ✅
    execute[[Program: program -> def*]]()=
        for(Defintion d:def*){
            if(d instanceof VarDefinition){
                execute[[d]]()
            }
        }
        <' Invocation to the main function>
        <call main>
        <halt>

        for(Definition d:def*){
            if(d instanceof FuncDefinition){
                execute[[d]]()
            }
        }

// PLANTILLAS ADDRESS (lvalue = Variable, ArrayAccess, FieldAccess)                     🆗 ----------------------------
1. Variable                                                                             ✅
    address[[Variable: expr -> ID]]()=
        // GLOBALES
        if(expr.def.offset==0){
            <pusha> expr.deffintion.offset
        }
        // PARAMETROS Y LOCALES
        else{
            <pusha bp>
            <push> expr.def.offset
            <addi>
        }

2. ArrayAccess                                                                          ✅
    address[[ArrayAccess: expr1 -> expr2 expr3]]()=
        address[[expr2]]()
        value[[expr3]]()
        cg.convertTo(expr3.type, IntType)
        <pushi> expr1.type.numberOfBytes
        <muli>
        <addi>

3. FieldAccess                                                                          ✅
    address[[FieldAccess: expr1 -> expr2 ID]]()=
        address[[expr2]]()
        <pushi> expr2.type.fields(ID).offset
        <addi>

// PLANTILLAS VALUE (expresiones)                                                       🆗 ----------------------------
1. Variable ->                                                                          ✅
    value[[Variable: expr -> ID]]()=
        address[[expr]]()
        <load> expr.type.suffix()

2. ArrayAccess                                                                          ✅
    value[[ArrayAccess: expr1 -> expr2 expr3]]()=
        address[[expr1]]()
        <load> expr1.type.suffix

3. FieldAccess                                                                          ✅
    value[[FieldAccess: expr1 -> expr2 ID]]() =
        address[[expr1]]()
        <load> expr1.type.suffix

4. ArithmeticOperation                                                                  ✅
    value[[ArithmeticOperation: expr1 -> expr2 OP=(+|-|*|/) expr3]]() =
        value[[expr2]]
        cg.convertTo(expr2.type, expr1.type)
        value[[expr3]]
        cg.converTo(expr3.type, expr1.type)
        cg.arithmetic(expr1.operator, expr1.type)

5. Cast                                                                                 ✅
    value[[Cast: expr1 -> type expr2]]()=
        value[[expr2]]()
        cg.convertTo(expr2.type, type)

6. CharLiteral                                                                          ✅
    value[[CharLiteral: expr -> CHAR_CONSTANT]]() =
        <pushb> expr.value

7. ComparationOperation                                                                 ✅
    value[[ComparationOperation: expr1 -> expr2 expr3]]()=
        value[[expr2]]()
        cg.convertTo(expr2.type, IntType)
        value[[expr3]]()
        cg.convertTo(expr3.type, IntType)
        cg.comparation(expr1.operator, expr1.type)

8. IntLiteral                                                                           ✅
    value[[IntLiteral: expr -> INT_CONSTANT]]()=
        <pushi> expr.value

9. Invocation                                                                           ✅
    value[[Invocation: expr1 -> expr2 expr3*]]()=
        for(Expression exp: expr3*)
            value[[exp]]
        <call> (expr2.name)

10. LogicOperation                                                                      ✅
    value[[LogicOperation: expr1 -> expr2 expr3]]() =
        value[[expr2]]()
        cg.convertTo(expr2.type, expr1.type)
        value[[expr3]]()
        cg.convertTo(expr3.type, expr1.type)
        cg.logic(expr1.operator, expr1.type)

11. RealLiteral                                                                         ✅
    value[[RealLiteral: expr -> REAL_CONSTANT]]()=
        <pusf> expr.value

12. UnaryMinus                                                                          ✅
    value[[UnaryMinus: expr1 -> expr2]]()=
        value[[expr2]]()
        cg.convertTo(expr2.type, expr1.type)
        <pushi> -1
        cg.converTo(IntType, expr1.type)
        <muli>

13. UnaryNot                                                                            ✅
    value[[UnaryNot: expr1 -> expr2]]()=
        value[[expr2]]()
        <not>



